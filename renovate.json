{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":preserveSemverRanges",
    ":semanticCommits"
  ],
  "mode": "full",
  "rebaseWhen": "behind-base-branch",
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchPackageNames": ["/.*/"],
      "groupName": null
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"]
    },
    {
      "matchUpdateTypes": ["patch", "digest", "pin"],
      "addLabels": ["patch"]
    },
    {
      "matchFileNames": [".github/workflows/**"],
      "addLabels": ["renovate", "github-actions"],
      "bumpVersions": [
        {
          "name": "Bump workflow version",
          "filePatterns": [".github/workflows/VERSION"],
          "matchStrings": ["^(?<version>[^\\s]+)"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchFileNames": ["kubernetes/charts/**"],
      "addLabels": ["renovate", "helm"],
      "bumpVersions": [
        {
          "name": "Bump chart version",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["version:\\s\"?(?<version>[^\\s\"]+)\"?"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchFileNames": ["terraform/modules/**"],
      "addLabels": ["renovate", "terraform"],
      "bumpVersions": [
        {
          "name": "Bump terraform module version",
          "filePatterns": ["{{packageFileDir}}/VERSION"],
          "matchStrings": ["^(?<version>[^\\s]+)"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["ansible", "ansible-galaxy"],
      "addLabels": ["renovate", "ansible"]
    }
  ]
}
