{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":preserveSemverRanges",
    ":semanticCommits"
  ],
  "mode": "full",
  "rebaseWhen": "behind-base-branch",
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchPackageNames": ["/.*/"],
      "groupName": null,
      "additionalBranchPrefix": "{{packageFileDir}}-"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"]
    },
    {
      "matchUpdateTypes": ["patch", "digest", "pin"],
      "addLabels": ["patch"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["renovate", "github-actions"],
      "bumpVersions": [
        {
          "name": "Bump workflow version",
          "filePatterns": [".github/workflows/VERSION"],
          "matchStrings": ["^(?<version>[^\\s]+)"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["helmv3", "helm-v3", "helm-values", "helmfile", "helm-requirements"],
      "addLabels": ["renovate", "helm"],
      "bumpVersions": [
        {
          "name": "Bump chart version",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["(?:^|\\n)version:\\s*\"?(?<version>[0-9.]+)\"?"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["terraform", "terraform-version", "terraform-vars", "terragrunt", "terragrunt-version", "tflint-plugin"],
      "addLabels": ["renovate", "terraform"],
      "bumpVersions": [
        {
          "name": "Bump terraform module version",
          "filePatterns": ["{{packageFileDir}}/VERSION"],
          "matchStrings": ["^(?<version>[^\\s]+)"],
          "bumpType": "{{#if isMajor}}major{{else if isMinor}}minor{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["ansible", "ansible-galaxy"],
      "addLabels": ["renovate", "ansible"]
    },
    {
      "matchManagers": ["kubernetes"],
      "addLabels": ["renovate", "kubernetes"]
    }
  ]
}
